# Copy this to .env and fill in all values before running

# ── Supabase ──────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ── Twilio (WhatsApp) ─────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── OpenAI ────────────────────────────────────────────
OPENAI_KEY=sk-...

# ── Bot Identity ──────────────────────────────────────
# The WhatsApp number this bot listens on (used to look up clinic in DB)
WHATSAPP_PHONE_ID=+14155238886

# ── Growth Swarm ──────────────────────────────────────
# Full public URL of this deployment (used in Ghost Room links)
BASE_URL=https://your-app.onrender.com

# Dashboard basic auth (CHANGE THESE IN PRODUCTION)
ADMIN_USER=admin
ADMIN_PASS=changeme_before_deploy

# ── Stripe (optional — required for paid plan flow) ───
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── 360dialog (optional — Pro plan clients only) ──────
# FALLBACK_TO_TWILIO=true

# ── Google Calendar (optional) ────────────────────────
# GOOGLE_CREDENTIALS_BASE64=base64_encoded_service_account_json

# ── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=production
